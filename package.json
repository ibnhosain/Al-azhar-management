{
  "name": "madrasa-dashboard",
  "private": true,
  "version": "1.5.1",
  "description": "Madrasa Management — offline desktop ERP (মাদরাসা ব্যবস্থাপনা)",
  "author": "Easy Coding Space",
  "type": "module",
  "main": "electron/main.cjs",
  "homepage": "https://ibnhosain.github.io/Al-azhar-management",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "electron:start": "wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_START_URL=http://localhost:5173/Al-azhar-management/ electron .",
    "electron:dev": "concurrently -k -n vite,electron -c green,cyan \"vite --port 5173 --strictPort\" \"npm:electron:start\"",
    "electron:vite": "cross-env BUILD_TARGET=electron vite build",
    "electron:pack": "npm run electron:vite && electron-builder --dir",
    "electron:build": "npm run electron:vite && electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "electron-updater": "^6.8.9",
    "node-sqlite3-wasm": "^0.8.59",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
